            "icon": "git-branch",
            "pages": [
              "admin/call-routing-overview",
              "admin/auto-receptionists",
              "admin/call-queues",
              "admin/business-hours-and-holidays"
            ]
          },
          {
            "group": "Advanced Features",
            "icon": "zap",
            "pages": [
              "admin/call-recording",
              "admin/call-monitoring",
              "admin/integrations",
              "admin/security-and-compliance",
              "admin/reporting-and-analytics"
            ]
          },
          {
            "group": "Go Live",
            "icon": "flag",
            "pages": [
              "admin/testing-and-go-live",
              "admin/go-live-email-templates"
