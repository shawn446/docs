{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Rivvet",
  "layout": "wide",
  "colors": {
    "primary": "#040404",
    "light": "#FFFFFF",
    "dark": "#040404"
  },
  "fonts": {
    "heading": {
      "family": "Roobert",
      "source": "/fonts/roobert.woff2",
      "format": "woff2",
      "weight": 600
    },
    "body": {
      "family": "Roobert",
      "source": "/fonts/roobert.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "styling": {
    "css": "/styles/custom.css"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#040404"
    }
  },
  "logo": {
    "light": "https://media.brand.dev/cad5d6e4-5400-4344-ac8e-5fcdc9b2e1ee.png",
    "dark": "https://media.brand.dev/cad5d6e4-5400-4344-ac8e-5fcdc9b2e1ee.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/introduction"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Admin Guide",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
